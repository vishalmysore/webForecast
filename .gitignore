# Python
__pycache__/
*.pyc
.venv/
venv/

# Raw checkpoint (271MB) — downloaded from HF, not committed. Regenerate via:
#   curl -L -o weights/model.safetensors \
#     https://huggingface.co/FareedKhan/timesfm-from-scratch-70m/resolve/main/model.safetensors
weights/
*.safetensors

# Full-precision ONNX export (259MB, over GitHub's 100MB limit). Only the
# int8 model (~65MB) is committed and served.
docs/model-config/*.onnx
!docs/model-config/timesfm_small.int8.onnx

# Raw results dataset (~3.6MB) for the World Cup demo — downloaded, not committed.
# Regenerate before running scripts/build_elo.py via:
#   curl -L -o scripts/data/results.csv \
#     https://raw.githubusercontent.com/martj42/international_results/master/results.csv
scripts/data/

# scratch
*.log

# OS
.DS_Store
Thumbs.db
